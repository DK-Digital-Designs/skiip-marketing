NEXT_PUBLIC_SITE_URL=http://localhost:3000

# v1 lead delivery
# Use mailto for simple no-backend email. Switch to api later for Supabase + Resend.
NEXT_PUBLIC_LEAD_DELIVERY=mailto
NEXT_PUBLIC_LEAD_EMAIL=hello@skiip.co

# Later lead API mode: Supabase
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Later lead API mode: email notifications
RESEND_API_KEY=
LEAD_NOTIFY_EMAIL=info@skiip.co.uk
LEAD_FROM_EMAIL=SKIIP <onboarding@resend.dev>

# Optional analytics
NEXT_PUBLIC_GA4_ID=

# Used to hash IP/user-agent metadata before storing leads
IP_HASH_SECRET=

# Optional comma-separated LAN/dev hosts if needed by Next dev origin protection
NEXT_ALLOWED_DEV_ORIGINS=192.168.0.150
